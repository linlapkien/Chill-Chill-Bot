{
  "manifest_version": 3,
  "name": "Chill Chill Bot v2",
  "version": "2.5",
  "description": "Plays Wolvesville automatically.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["debugger", "tabs", "scripting", "storage"],
  "host_permissions": ["https://www.wolvesville.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Chill Chill Bot",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.wolvesville.com/*"],
      "js": ["lib/jquery-3.7.1.min.js", "ChillChillBot.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["ChillChillBot.js", "injected-bypass.js"],
      "matches": ["https://www.wolvesville.com/*"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
